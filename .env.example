# Copy to services/coach/.env — NEVER commit real keys

# Primary: Ollama Cloud
OLLAMA_API_KEY=
OLLAMA_API_BASE=https://ollama.com/v1
RELINK_LLM_PROVIDER=ollama
# Bare Ollama Cloud ids (not openai/… — that prefix is LiteLLM-only)
RELINK_MODEL_COACH=glm-5.2
RELINK_MODEL_STRUCT=kimi-k2.7-code

# Fallback: Vertex Gemini (ADC / Cloud Run SA)
RELINK_LLM_FALLBACK=vertex
RELINK_GEMINI_MODEL=gemini-2.0-flash
GOOGLE_CLOUD_PROJECT=gcpdevelopment-464720
GOOGLE_CLOUD_LOCATION=us-central1
RELINK_ALLOW_MOCK_FALLBACK=1

# Web → coach
COACH_URL=http://127.0.0.1:8787
COACH_PORT=8787
